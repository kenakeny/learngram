# Database
DATABASE_URL=postgresql://learngram:learngram@localhost:5432/learngram

# LLM provider: "gemini" or "ollama"
LLM_PROVIDER=ollama
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_GEN_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Embedding provider: "gemini" or "ollama"
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=768

# Ollama — set OLLAMA_GEN_MODEL to whatever you have pulled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEN_MODEL=gemma4
OLLAMA_EMBED_MODEL=nomic-embed-text
